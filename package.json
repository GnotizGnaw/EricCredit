{
  "name": "vuestic-admin",
  "private": true,
  "version": "3.1.0",
  "type": "module",
  "workspaces": [
    "e2e"
  ],
  "scripts": {
    "prepare": "husky install",
    "dev": "vite",
    "build": "npm run lint && vue-tsc --noEmit && vite build",
    "build:ci": "vite build",
    "start:ci": "serve -s ./dist",
    "prelint": "npm run format",
    "lint": "eslint \"./src/**/*.{ts,js,vue}\" --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "yarn workspace e2e test",
    "e2e:update-snapshots": "yarn workspace e2e update"
  },
  "lint-staged": {
    "./src/**/*.{ts,js,vue}": [
      "npm run lint"
    ]
  },
  "dependencies": {
    "@gtm-support/vue-gtm": "^3.2.0",
    "@vuestic/compiler": "0.2.9",
    "@vuestic/tailwind": "^0.1.3",
    "@vueuse/core": "^14.2.0",
    "chart.js": "^4.5.1",
    "chartjs-chart-geo": "^4.2.8",
    "epic-spinners": "^2.0.0",
    "flag-icons": "^6.15.0",
    "ionicons": "^4.6.3",
    "medium-editor": "^5.23.3",
    "pinia": "^2.3.0",
    "register-service-worker": "^1.7.1",
    "sass": "^1.97.3",
    "serve": "^14.2.6",
    "uuid": "^11.0.3",
    "vue": "3.5.11",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.0",
    "vuestic-ui": "^1.10.4"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@storybook/addon-essentials": "latest",
    "@storybook/addon-interactions": "latest",
    "@storybook/addon-links": "latest",
    "@storybook/blocks": "latest",
    "@storybook/vue3": "latest",
    "@storybook/vue3-vite": "latest",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.0",
    "autoprefixer": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-storybook": "^0.11.0",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.4.0",
    "postcss": "^8.5.1",
    "prettier": "^3.5.2",
    "storybook": "latest",
    "tailwindcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "yarn@4.9.2"
}